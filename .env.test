# Dummy Firebase config for vitest. Values are intentionally fake —
# Firebase initializes without network calls, so non-empty strings
# satisfy the SDK's format assertions and let module graphs load cleanly.
VITE_FIREBASE_API_KEY=AIzaSyDummy1234567890abcdefghijklmnopq
VITE_FIREBASE_AUTH_DOMAIN=dummy-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=dummy-project
VITE_FIREBASE_STORAGE_BUCKET=dummy-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abc123def456789012345
