rules_version = "2";
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRole(role) {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function hasAnyRole(roles) {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles;
    }

    function canAssignRole(targetRole) {
      let userRole = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      // Only admins can assign any role
      return userRole == 'admin' ||
             // Staff can assign applicant, staff, alumni, student, and mentor roles
             (userRole == 'staff' && targetRole in ['applicant', 'staff', 'alumni', 'student', 'mentor']);
    }

    function isValidRoleTransition(currentRole, newRole) {
      // Mirror src/services/permissions.ts:isValidRoleTransition. Keep these
      // in lockstep — drift here means client validation passes but the rule
      // rejects (or vice versa).
      let allowedTransitions = {
        'applicant': ['student', 'alumni'],
        'student': ['alumni', 'applicant'],
        'alumni': ['applicant', 'student', 'mentor'],
        'mentor': ['staff', 'alumni'],
        'staff': ['admin', 'applicant', 'mentor'],
        'admin': ['staff', 'applicant', 'alumni', 'mentor'],
        'content_editor': ['admin', 'staff']
      };
      return newRole in allowedTransitions[currentRole] || currentRole == newRole;
    }

    // Users collection rules
    match /users/{userId} {
      // Users can read their own profile; staff/admin can read any (needed
      // for the admin user-management screen and the alumni directory).
      allow read: if isOwner(userId) || hasAnyRole(['staff', 'admin']);

      // Users can update their own profile (except role). updatedAt is
      // allowed because DatabaseService.updateUserProfile stamps it on
      // every write.
      allow update: if isOwner(userId) &&
                   request.resource.data.diff(resource.data).affectedKeys()
                   .hasOnly(['displayName', 'photoURL', 'avatarSlot', 'bio', 'program', 'applicationStatus', 'directoryHidden', 'emailPreferences', 'updatedAt']);

      // Only admins can create users with roles
      allow create: if hasRole('admin') ||
                   // Allow self-registration for applicant/alumni roles
                   (request.auth.uid == userId &&
                    request.resource.data.role in ['applicant', 'alumni']);

      // Role assignment validation. updatedAt is allowed alongside role
      // because DatabaseService.updateUserProfile always stamps it on
      // every write — without it, every admin role change would be
      // rejected as "insufficient permissions".
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'updatedAt']) &&
                   canAssignRole(request.resource.data.role) &&
                   isValidRoleTransition(resource.data.role, request.resource.data.role);

      // Self-elevation: applicant -> staff for @staija.org users who have
      // proven mailbox ownership by verifying their email. The matching
      // client-side flow lives in src/services/auth.ts:ensureUserProfile.
      // Only fires once (subsequent updates fall back to canAssignRole).
      allow update: if request.auth.uid == userId &&
                       resource.data.role == 'applicant' &&
                       request.resource.data.role == 'staff' &&
                       request.auth.token.email_verified == true &&
                       request.auth.token.email.lower().matches('.*@staija[.]org') &&
                       request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['role', 'updatedAt']);
    }

    // Applications collection rules
    //
    // Two writers, each with a different scope:
    //   - Applicant (the owner) can author + edit their application
    //     while it's still in `draft` status, and submit it (draft →
    //     submitted). Once submitted, the record is locked from the
    //     applicant side so staff review what was actually submitted.
    //   - Staff/admin can change the four review-related fields
    //     (status, reviewedAt, reviewedBy, feedback) at any time, but
    //     can't touch the applicant's personalInfo / academicInfo /
    //     motivation / references / etc.
    match /applications/{applicationId} {
      // Read: applicant sees their own; staff/admin see all.
      allow read: if (request.auth != null && isOwner(resource.data.userId)) ||
                     hasAnyRole(['staff', 'admin']);

      // Create: applicant creates their own application. The userId on
      // the new doc must match their uid, and they can only set
      // status to a self-managed value (draft or submitted) — they
      // can't conjure an already-accepted application.
      allow create: if request.auth != null &&
                    isOwner(request.resource.data.userId) &&
                    request.resource.data.status in ['draft', 'submitted'];

      // Update: three valid paths, OR'd together.
      allow update: if (
          // 1. Applicant editing their still-draft application.
          //    - Current status must be 'draft' (post-submission lock)
          //    - May not write the staff-only review fields
          //    - New status may only be 'draft' or 'submitted'
          //      (i.e. they can save another draft or hit submit;
          //      they cannot self-accept)
          request.auth != null &&
          isOwner(resource.data.userId) &&
          resource.data.status == 'draft' &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['reviewedAt', 'reviewedBy', 'feedback']) &&
          request.resource.data.status in ['draft', 'submitted']
        ) || (
          // 2. Applicant attaching documents to a freshly-submitted
          //    application. The file URLs land on the doc *after*
          //    Storage uploads complete (NewApplication.vue creates
          //    with status='submitted', then patches `documents`).
          //    Locked to that one field, and only allowed while the
          //    application hasn't moved into formal review yet —
          //    no editing attachments after staff start reviewing.
          request.auth != null &&
          isOwner(resource.data.userId) &&
          resource.data.status in ['draft', 'submitted'] &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['documents'])
        ) || (
          // 3. Staff/admin reviewing — narrow allow-list of fields.
          hasAnyRole(['staff', 'admin']) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'reviewedAt', 'reviewedBy', 'feedback'])
        );

      // Delete: applicant can withdraw their own at any stage; staff
      // and admin can also remove records (for cleanup / GDPR).
      allow delete: if (request.auth != null && isOwner(resource.data.userId)) ||
                       hasAnyRole(['staff', 'admin']);
    }

    // Per-(user, program) application drafts. Mirrors what the apply
    // wizard auto-saves to localStorage so the in-progress form follows
    // the *account*, not just the browser. Doc ID is deterministic:
    // `${uid}_${program}`. Submission flow deletes the draft after the
    // real `applications/{auto-id}` doc is created.
    match /applicationDrafts/{draftId} {
      // Read: applicant only. No staff visibility on drafts — these are
      // pre-submission scratchpads, not records under review.
      allow read: if request.auth != null && isOwner(resource.data.userId);

      // Create / update: owner only. `userId` on the doc must match the
      // caller; `program` must be one of the known slugs. We don't lock
      // the payload shape — the client owns the wizard schema and may
      // add fields over time.
      allow create: if request.auth != null &&
                    isOwner(request.resource.data.userId) &&
                    request.resource.data.program in ['stepup-scholars', 'dynamerge'];
      allow update: if request.auth != null &&
                    isOwner(resource.data.userId) &&
                    isOwner(request.resource.data.userId);

      // Delete: applicant clears their own (e.g. after submit, or via
      // the dashboard's "Discard" button). Staff/admin can also clean
      // up — symmetric with applications above.
      allow delete: if (request.auth != null && isOwner(resource.data.userId)) ||
                       hasAnyRole(['staff', 'admin']);
    }

    // Programs collection rules
    match /programs/{programId} {
      // Everyone can read programs
      allow read: if true;

      // Only staff and admins can create/update programs
      allow write: if hasAnyRole(['staff', 'admin']);

      // Per-program version history written by saveProgramWithHistory().
      // Append-only from the client side — no updates, no deletes; the
      // /admin/programs UI restores by writing a new version, not by
      // mutating an old one. Cleanup of older entries is a separate
      // future job.
      match /history/{snapshotId} {
        allow read: if hasAnyRole(['staff', 'admin']);
        allow create: if hasAnyRole(['staff', 'admin']);
        allow update, delete: if false;
      }
    }

    // The /content collection (legacy in-app CMS) was retired when STAIJA
    // moved editorial workflows to Contentful. The cms_blogPosts and
    // cms_events collections below are the read-only Firestore mirror
    // populated by the Contentful webhook.

    // Contact messages collection rules
    match /contact_messages/{messageId} {
      // Anyone can create contact messages
      allow create: if isAuthenticated();

      // Only staff and admins can read contact messages
      allow read: if hasAnyRole(['staff', 'admin']);
    }

    // Donations: written exclusively by the Paystack webhook (admin SDK
    // bypasses these rules). Donors can read their own donation rows;
    // admins can read all. No client writes.
    match /donations/{ref} {
      allow read: if isAuthenticated() && (
        resource.data.donorUid == request.auth.uid ||
        hasAnyRole(['staff', 'admin'])
      );
      allow write: if false;
    }

    // CMS mirror collections — public read (matches the public blog/events
    // pages). Writes are server-only (Contentful webhook via admin SDK).
    match /cms_blogPosts/{entryId} {
      allow read: if true;
      allow write: if false;
    }
    match /cms_events/{entryId} {
      allow read: if true;
      allow write: if false;
    }

    // LMS course content mirror. Read-locked to authenticated users — course
    // content shouldn't be public. Writes are server-only (Contentful webhook
    // via admin SDK, same as the cms_* collections above).
    match /cms_courses/{entryId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    match /cms_modules/{entryId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    match /cms_lessons/{entryId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    match /cms_assignmentSpecs/{entryId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Audit logs collection rules (for tracking role changes)
    match /audit_logs/{logId} {
      // Only admins can read audit logs
      allow read: if hasRole('admin');

      // System can create audit logs
      allow create: if hasRole('admin') || hasRole('staff');
    }

    // Mentor↔student assignments. Created by staff/admin (no client-side
    // assignment UI yet — set up in Firestore directly or via a future admin
    // tool). Mentors see only their own pairings. Students could conceivably
    // see "who is my mentor", but that surface doesn't exist yet, so the
    // student-side read is omitted until a UX is decided.
    match /mentor_assignments/{assignmentId} {
      allow read: if isAuthenticated() && (
        resource.data.mentorId == request.auth.uid ||
        hasAnyRole(['staff', 'admin'])
      );
      allow create, update, delete: if hasAnyRole(['staff', 'admin']);
    }

    // Mentor feedback. The mentor who wrote it can read+update their own;
    // staff/admin can read everything. Students cannot read their own
    // feedback yet — that surface needs a UX decision (timing, response,
    // etc.) and is intentionally out of scope until that's designed.
    match /mentor_feedback/{feedbackId} {
      allow read: if isAuthenticated() && (
        resource.data.mentorId == request.auth.uid ||
        hasAnyRole(['staff', 'admin'])
      );
      allow create: if isAuthenticated() &&
                       request.resource.data.mentorId == request.auth.uid &&
                       hasRole('mentor');
      allow update: if isAuthenticated() &&
                       resource.data.mentorId == request.auth.uid &&
                       hasRole('mentor') &&
                       request.resource.data.mentorId == resource.data.mentorId &&
                       request.resource.data.studentId == resource.data.studentId;
      allow delete: if hasAnyRole(['staff', 'admin']);
    }

    // --- LMS operational collections -----------------------------------
    //
    // All writes go through Cloud Functions (admin SDK bypasses these
    // rules). Direct client writes are denied so business rules — like
    // "you can only enroll yourself if a callable says so", or "grade
    // updates only flip approved fields" — live in one place.

    // Cohorts: course cycles. Any authenticated user can read — the
    // data here is operational metadata, not sensitive (no PII), and
    // students need to read their own cohort to render the dashboard.
    // Direct staff/admin writes from /admin/cohorts; the enrollment
    // flow goes through enrollStudent (which reads but doesn't write
    // cohorts) so there's no callable to gate it on.
    match /cohorts/{cohortId} {
      allow read: if isAuthenticated();
      allow create, update: if hasAnyRole(['staff', 'admin']);
      allow delete: if hasRole('admin');
    }

    // Enrollments. Student or assigned mentor can read their own;
    // staff/admin can read all. Writes are server-only.
    match /enrollments/{enrollmentId} {
      allow read: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid ||
        resource.data.mentorId == request.auth.uid ||
        hasAnyRole(['staff', 'admin'])
      );
      allow write: if false;
    }

    // Lesson progress. Owner can read, mentor can read for their
    // assigned student, staff/admin all access. Writes are server-only
    // so completion can't be self-serviced from a tampered client.
    match /lesson_progress/{progressId} {
      allow read: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid ||
        hasAnyRole(['staff', 'admin'])
      );
      allow write: if false;
    }

    // Assignment submissions. Student creates own, reads own; mentor
    // reads + grades their assigned students'; staff/admin all access.
    // Grading writes go through gradeSubmission to keep the side-effect
    // (notification, audit) coupled.
    match /assignment_submissions/{submissionId} {
      allow read: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid ||
        resource.data.mentorId == request.auth.uid ||
        hasAnyRole(['staff', 'admin'])
      );
      allow write: if false;
    }

    // Live sessions. Cohort members and staff/admin can read.
    match /live_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Session RSVPs. Owner can read own; staff/admin all access. Writes
    // server-only so RSVP triggers attendance/notification side-effects.
    match /session_rsvps/{rsvpId} {
      allow read: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid ||
        hasAnyRole(['staff', 'admin'])
      );
      allow write: if false;
    }
  }
}