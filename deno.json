{
  "imports": {
    "vue": "npm:vue@^3.5.18",
    "vue-router": "npm:vue-router@^4.4.5",
    "firebase/app": "npm:firebase@^10.7.1/app",
    "firebase/auth": "npm:firebase@^10.7.1/auth",
    "firebase/firestore": "npm:firebase@^10.7.1/firestore",
    "firebase/storage": "npm:firebase@^10.7.1/storage",
    "firebase/analytics": "npm:firebase@^10.7.1/analytics",
    "firebase/performance": "npm:firebase@^10.7.1/performance",
    "contentful-management": "npm:contentful-management@^10.0.0",
    "@vitejs/plugin-vue": "npm:@vitejs/plugin-vue@^6.0.1",
    "vite": "npm:vite@^7.1.2",
    "typescript": "npm:typescript@~5.8.3",
    "vue-tsc": "npm:vue-tsc@^3.0.5",
    "motion-v": "npm:motion-v@^1.7.1",
    "lottie-web": "npm:lottie-web@^5.12.2",
    "vue-i18n": "npm:vue-i18n@^9.13.1",
    "@iconify/vue": "npm:@iconify/vue@^5.0.0",
    "vitest": "npm:vitest@^4.1.0",
    "happy-dom": "npm:happy-dom@^18.0.1",
    "tailwindcss": "npm:tailwindcss@^4.1.12",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.12"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": ["deno.window"],
    "strict": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "files": {
      "include": ["src/", "scripts/"]
    },
    "options": {
      "useTabs": false,
      "lineWidth": 80,
      "indentWidth": 2,
      "semiColons": true,
      "singleQuote": true,
      "proseWrap": "preserve"
    }
  },
  "tasks": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "setup": "deno run --allow-read --allow-write --allow-env scripts/setup-env.ts",
    "cache": "deno run --allow-net --allow-read scripts/cache-deps.ts",
    "test": "deno run -A npm:vitest run",
    "test:watch": "deno run -A npm:vitest",
    "lint": "deno lint",
    "fmt": "deno fmt"
  }
}
