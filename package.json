{
   "name": "staija",
   "private": true,
   "version": "0.0.1",
   "type": "module",
   "scripts": {
      "dev": "vite",
      "dev:staging": "vite --mode staging",
      "build": "vue-tsc -b && vite build",
      "build:staging": "vue-tsc -b && vite build --mode staging",
      "preview": "vite preview",
      "deploy:staging": "firebase deploy --project staging",
      "deploy:staging:rules": "firebase deploy --project staging --only firestore,storage",
      "deploy:staging:functions": "firebase deploy --project staging --only functions",
      "deploy:prod": "firebase deploy --project prod",
      "deploy:prod:rules": "firebase deploy --project prod --only firestore,storage",
      "deploy:prod:functions": "firebase deploy --project prod --only functions",
      "test": "vitest run",
      "test:watch": "vitest",
      "avatars:generate": "tsx tools/avatars/generate.ts",
      "avatars:label": "tsx tools/avatars/parse-and-label.ts",
      "avatars:clean": "tsx tools/avatars/clean.ts",
      "avatars:thumbs": "tsx tools/avatars/thumbs.ts",
      "social:capture": "node tools/social/capture.cjs",
      "banner:capture": "node tools/banner/capture.cjs",
      "lms:seed": "tsx tools/lms-seed/seed.ts seed",
      "lms:clear": "tsx tools/lms-seed/seed.ts clear",
      "lms:republish": "tsx tools/lms-seed/seed.ts republish",
      "demo": "DEMO=1 bddgen --config playwright.demo.config.ts && DEMO=1 playwright test --config playwright.demo.config.ts"
   },
   "dependencies": {
      "@contentful/rich-text-html-renderer": "^17.2.2",
      "@contentful/rich-text-types": "^17.2.7",
      "@dicebear/core": "^9.4.2",
      "@iconify/vue": "5.0.1",
      "@tiptap/extension-link": "^3.27.4",
      "@tiptap/extension-placeholder": "^3.28.0",
      "@tiptap/extension-underline": "^3.27.4",
      "@tiptap/pm": "^3.27.4",
      "@tiptap/starter-kit": "^3.27.4",
      "@tiptap/vue-3": "^3.27.4",
      "@vercel/analytics": "^2.0.1",
      "@vercel/speed-insights": "^2.0.0",
      "@vueuse/core": "^14.3.0",
      "contentful-management": "12.8.0",
      "firebase": "^12.16.0",
      "lottie-web": "^5.13.0",
      "motion-v": "^2.3.0",
      "vue": "^3.5.39",
      "vue-i18n": "^11.4.7",
      "vue-router": "^5.1.0"
   },
   "devDependencies": {
      "@huggingface/inference": "^4.13.23",
      "@playwright/test": "^1.61.1",
      "@tailwindcss/vite": "^4.3.2",
      "@vitejs/plugin-vue": "^6.0.7",
      "@vue/test-utils": "^2.4.11",
      "@vue/tsconfig": "^0.9.1",
      "dotenv": "^17.4.2",
      "happy-dom": "^20.10.6",
      "jimp": "^1.6.1",
      "playwright": "^1.61.1",
      "playwright-bdd": "^9.2.0",
      "potrace": "^2.1.8",
      "rollup-plugin-visualizer": "^7.0.1",
      "svgo": "^4.0.2",
      "tailwindcss": "^4.3.2",
      "tsx": "^4.23.1",
      "typescript": "~6.0.3",
      "vite": "^8.1.4",
      "vitest": "^4.1.10",
      "vue-tsc": "latest"
   },
   "overrides": {
      "phin": "3.7.1",
      "uuid": "^11.1.1",
      "@vercel/analytics": {
         "vue-router": "$vue-router"
      },
      "@vercel/speed-insights": {
         "vue-router": "$vue-router"
      },
      "@cucumber/messages": {
         "uuid": "^11.1.1"
      }
   }
}
