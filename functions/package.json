{
  "name": "staija-functions",
  "version": "0.1.0",
  "description": "Firebase Functions for STAIJA — Contentful webhook + transactional email",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "busboy": "^1.6.0",
    "contentful-management": "^10.46.4",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^7.2.5",
    "groq-sdk": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "typescript": "~5.8.3"
  }
}
