rules_version = "2";
service firebase.storage {
  match /b/{bucket}/o {
    // Pre-submission staging for applicants' files + audio recordings.
    // Picked-from-disk files (transcript / ID / showcase) and in-browser
    // audio answers land here the moment they're selected, so the
    // applicant's draft can reference them across devices instead of
    // forcing a re-attach on every resume. Owner-only — explicitly NO
    // staff/admin read access: staging contents are pre-submission and
    // may include sensitive ID scans the applicant hasn't yet committed
    // to sharing. Once they hit Submit, the finalize Cloud Function
    // copies the bytes into applications/<uid>/<applicationId>/... and
    // wipes staging.
    //
    // Lives at a SEPARATE prefix from applications/ (not a sub-path)
    // because Firebase Storage rules are additive across overlapping
    // matches — nesting under applications/{uid}/_staging would still
    // inherit the outer block's staff/admin read grant. The separate
    // root prefix keeps it cleanly owner-private.
    match /applicationStaging/{uid}/{rest=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid &&
        request.resource.size < 25 * 1024 * 1024;
    }

    // Application uploads (transcript / ID / optional showcase): only the
    // applicant can write to their own folder; only admins / staff can
    // read. 25MB cap is generous enough for a ~90s phone video clip in
    // the optional showcase slot; transcripts and IDs still fit easily.
    match /applications/{uid}/{rest=**} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'staff']
      );
      allow write: if request.auth != null && request.auth.uid == uid &&
        request.resource.size < 25 * 1024 * 1024;
    }

    // Reference letters: written exclusively by the `submitReferenceLetter`
    // Cloud Function (admin SDK bypasses rules). No client writes; only
    // staff/admin can read.
    match /references/{rest=**} {
      allow read: if request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'staff'];
      allow write: if false;
    }

    // CMS / public assets if any (handled via Contentful, but allow public
    // read here for any future public/ folder we might use).
    match /public/{rest=**} {
      allow read: if true;
      allow write: if false;
    }

    // Program editor uploads — admin/staff write images for hero, features,
    // mentors via the /admin/programs page. Public read so program pages
    // can render the images without auth.
    match /programs/{rest=**} {
      allow read: if true;
      allow write: if request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'staff'] &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }

    // User avatar uploads. Owner writes their own (2 MB cap, image MIME),
    // any authenticated user can read (avatars surface in the alumni
    // directory and mentor lists). The default-deny match below was
    // silently blocking writes from /account/settings before this rule.
    match /avatars/{uid}/{rest=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.uid == uid &&
        request.resource.size < 2 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }

    // LMS assignment submissions. Path is submissions/{uid}/{enrollmentId}/
    // so ownership is enforceable directly here. Staff/admin can read all;
    // mentors can read for their assigned students (rule grants mentor
    // role broadly here — finer-grained mentor↔student check is done at
    // the Firestore document layer where assignment_submissions has the
    // mentorId denormalized). 10 MB cap matches the default
    // assignmentSpec.maxFileSizeMb in Contentful.
    match /submissions/{uid}/{rest=**} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'staff', 'mentor']
      );
      allow write: if request.auth != null &&
        request.auth.uid == uid &&
        request.resource.size < 10 * 1024 * 1024;
    }

    // LMS content asset staging. Clients (staff/admin only) write a
    // file here, then call the lmsAssetUpload Cloud Function which
    // copies it into Contentful and deletes the staging blob. Path is
    // scoped to the writer's uid so the function can re-check it
    // server-side. 10 MB cap matches the Contentful Asset budget we
    // typically work with for course covers / lesson attachments.
    match /cms/{uid}/{rest=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null &&
        request.auth.uid == uid &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'staff'] &&
        request.resource.size < 10 * 1024 * 1024;
    }

    // Default deny.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
